---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import Terminal from './Terminal.astro';
import '../styles/global.css';
import '../styles/components/message-box.css';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  image?: string;
  currentPage?: string;
  themeColor?: string;
  /** Hide the default bottom nav (for pages with custom nav like blog posts) */
  hideBottomNav?: boolean;
  /** Page language for html[lang] and og:locale (default: 'en') */
  pageLang?: 'en' | 'vi';
  /** Open Graph type (default: 'website', use 'article' for blog posts) */
  ogType?: string;
}

const {
  title,
  description,
  keywords = "web developer, portfolio, javascript, typescript, node.js, docker, software engineer",
  image = '/assets/icon/main.png',
  currentPage = '',
  themeColor = '#000000',
  hideBottomNav = false,
  pageLang = 'en',
  ogType = 'website'
} = Astro.props;

const htmlLang = pageLang;
const ogLocale = pageLang === 'vi' ? 'vi_VN' : 'en_US';
const metaLanguage = pageLang === 'vi' ? 'Vietnamese' : 'English';

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang={htmlLang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="generator" content={Astro.generator}>
  
  <!-- Favicon / Icons -->
  <link rel="icon" type="image/png" href={new URL('/assets/icon/main.png', Astro.site).toString()}>
  <link rel="apple-touch-icon" href={new URL('/assets/icon/main.png', Astro.site).toString()}>
  <link rel="shortcut icon" type="image/x-icon" href={new URL('/assets/icon/main.png', Astro.site).toString()}>

  <!-- Primary Meta Tags -->
  <title>{title}</title>
  <meta name="title" content={title}>
  <meta name="description" content={description}>
  <meta name="keywords" content={keywords}>
  <meta name="theme-color" content={themeColor}>
  <link rel="canonical" href={canonicalURL.toString()}>
  
  <!-- RSS Feed -->
  <link rel="alternate" type="application/rss+xml" href="/rss.xml" title="Khoa Ngo Blogs RSS">
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={ogType}>
  <meta property="og:url" content={canonicalURL.toString()}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={new URL(image, Astro.site).toString()}>
  <meta property="og:locale" content={ogLocale}>
  <meta property="og:site_name" content="Khoa Ngo Portfolio">
  
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:url" content={canonicalURL.toString()}>
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={new URL(image, Astro.site).toString()}>
  
  <!-- Additional SEO -->
  <meta name="author" content="Khoa Ngo">
  <meta name="robots" content="index, follow">
  <meta name="language" content={metaLanguage}>

  <Analytics />
  <SpeedInsights />
  
  <!-- Fonts preload -->
  <link rel="preload" href="/fonts/JetBrainsMono-Regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/JetBrainsMono-SemiBold.woff2" as="font" type="font/woff2" crossorigin>
  
  <!-- Theme initialization (prevent flash) -->
  <script is:inline>
    (function() {
      const theme = localStorage.getItem('theme') || 
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.dataset.theme = theme;
      document.documentElement.style.colorScheme = theme;
    })();
  </script>

  <!-- Breadcrumb Structured Data -->
  {currentPage && currentPage !== 'home' && (
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": Astro.site?.toString()
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": currentPage.charAt(0).toUpperCase() + currentPage.slice(1),
          "item": new URL(Astro.url.pathname, Astro.site).toString()
        }
      ]
    })} />
  )}
</head>
<body>
  <canvas id="grid-canvas" aria-hidden="true" style="position:fixed;inset:0;width:100%;height:100%;z-index:-1;pointer-events:none;"></canvas>
  <Header currentPage={currentPage} />
  
  <main>
    <slot />
  </main>
  
  <Footer />
  
  {!hideBottomNav && <BottomNav currentPage={currentPage} variant="main" />}
  <Terminal />
  <script>
    import { initGridCanvas } from '../scripts/grid-canvas';
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initGridCanvas);
    } else {
      initGridCanvas();
    }
  </script>
</body>
</html>

<style is:global>
  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
  
  main {
    flex: 1;
    padding-bottom: 80px; /* Space for bottom nav */
  }
  
  @media (max-width: 500px) {
    main {
      padding-bottom: 30px;
    }
  }
</style>

