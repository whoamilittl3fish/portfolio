---
/**
 * Shared bottom navigation bar component
 * Used across main pages and blog posts with different configurations
 */
import '../styles/components/bottom-nav.css';

interface Props {
  /** Current page for highlighting active nav link */
  currentPage?: string;
  /** Variant: 'main' for home/projects/blogs, 'blog' for blog posts */
  variant?: 'main' | 'blog';
  /** Blog-specific props */
  lang?: 'en' | 'vi';
  slug?: string;
  langs?: ('en' | 'vi')[];
}

const { 
  currentPage = '', 
  variant = 'main',
  lang = 'en',
  slug = '',
  langs = ['en', 'vi']
} = Astro.props;

const navLinks = [
  { href: '/', label: 'home' },
  { href: '/projects', label: 'projects' },
  { href: '/blogs', label: 'blogs' },
];

---

<nav class="bottom-nav" aria-label="Navigation">
  <div class="bottom-nav__pill">
    {variant === 'main' && navLinks.map(link => (
      <a 
        class:list={['bottom-nav__link', { 'is-active': currentPage === link.label }]}
        href={link.href}
      >
        {link.label}
      </a>
    ))}
    
    {variant === 'blog' && (
      <>
        {lang === 'en' ? (
          langs.includes('vi') ? (
            <a href={`/blogs/vi/${slug}`} class="bottom-nav__link">vi</a>
          ) : (
            <span class:list={['bottom-nav__link', 'is-disabled']}>vi</span>
          )
        ) : (
          langs.includes('en') ? (
            <a href={`/blogs/en/${slug}`} class="bottom-nav__link">en</a>
          ) : (
            <span class:list={['bottom-nav__link', 'is-disabled']}>en</span>
          )
        )}
        <a href="/" class="bottom-nav__link">home</a>
        <a href="/blogs" class="bottom-nav__link">blogs</a>
      </>
    )}
    
    <a
      href="/contact"
      class:list={['bottom-nav__contact', { 'is-active': currentPage === 'contact' }]}
      aria-label="Contact"
    >ZSK</a>

    <span class="bottom-nav__divider"></span>

    <button
      id="terminal-trigger"
      class="bottom-nav__terminal"
      type="button"
      aria-label="Open terminal"
      aria-expanded="false"
      aria-controls="terminal-popup"
    >&gt;_</button>

    <span class="bottom-nav__divider"></span>

    <button
      id="bottom-theme-toggle"
      class="bottom-nav__theme"
      type="button"
      aria-label="Toggle theme"
    >
      <span class="bottom-nav__theme-icon">☀️</span>
    </button>

    <button 
      id="bottom-back-to-top" 
      class="bottom-nav__theme" 
      type="button" 
      aria-label="Back to top"
    >
      ▲
    </button>
  </div>
</nav>

<script>
  import { forceRepaint } from '../scripts/utils/dom';

  const themeToggle = document.getElementById('bottom-theme-toggle');
  const themeIcon = themeToggle?.querySelector('.bottom-nav__theme-icon');

  function updateThemeIcon(): void {
    if (!themeIcon) return;
    const isDark = document.documentElement.dataset.theme === 'dark';
    themeIcon.textContent = isDark ? '🌙' : '☀️';
  }
  
  function toggleTheme(): void {
    const current = document.documentElement.dataset.theme;
    const next = current === 'dark' ? 'light' : 'dark';
    
    // Disable transitions temporarily
    const style = document.createElement('style');
    style.textContent = '* { transition: none !important; }';
    document.head.appendChild(style);
    
    // Update theme
    document.documentElement.dataset.theme = next;
    document.documentElement.style.colorScheme = next;
    localStorage.setItem('theme', next);
    
    // Update icon
    updateThemeIcon();
    
    // Force repaint (critical for mobile)
    forceRepaint();
    
    // Re-enable transitions
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        document.head.removeChild(style);
      });
    });
    
    // Dispatch event
    window.dispatchEvent(new CustomEvent('themechange', { detail: { theme: next } }));
  }
  
  // Set initial icon
  updateThemeIcon();
  
  // Watch for theme changes
  const observer = new MutationObserver(updateThemeIcon);
  observer.observe(document.documentElement, { 
    attributes: true, 
    attributeFilter: ['data-theme'] 
  });
  
  // Handle click
  themeToggle?.addEventListener('click', toggleTheme);
  
  // Back to top
  const backToTop = document.getElementById('bottom-back-to-top');
  backToTop?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
  
  /**
   * Footer collision detection
   * Nav sticks above footer when scrolled to bottom (like sticky from bottom)
   */
  const bottomNav = document.querySelector('.bottom-nav') as HTMLElement;
  const footer = document.querySelector('.footer') as HTMLElement;
  const spacing = 16;
  
  function isMobile(): boolean {
    return window.innerWidth <= 500;
  }
  
  function getDefaultBottom(): number {
    return isMobile() ? 16 : 24; // var(--space-md) vs var(--space-xl)
  }
  
  function updateNavPosition(): void {
    if (!bottomNav || !footer) return;
    
    const footerTop = footer.offsetTop;
    const navHeight = bottomNav.offsetHeight;
    const scrollY = window.scrollY;
    const windowHeight = window.innerHeight;
    const defaultBottom = getDefaultBottom();
    
    // Position where nav bottom would touch footer top (when fixed)
    const navBottomWhenFixed = scrollY + windowHeight - defaultBottom;
    const collisionPoint = footerTop - spacing;
    
    if (navBottomWhenFixed > collisionPoint) {
      // Stick nav just above footer using absolute positioning
      bottomNav.style.position = 'absolute';
      bottomNav.style.bottom = 'auto';
      bottomNav.style.top = `${footerTop - navHeight - spacing}px`;
    } else {
      // Normal fixed position at bottom
      bottomNav.style.position = '';
      bottomNav.style.bottom = '';
      bottomNav.style.top = '';
    }
  }
  
  // Throttled scroll handler
  let ticking = false;
  function onScroll(): void {
    if (!ticking) {
      requestAnimationFrame(() => {
        updateNavPosition();
        ticking = false;
      });
      ticking = true;
    }
  }
  
  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', updateNavPosition);
  updateNavPosition();
</script>

