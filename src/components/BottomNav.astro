---
import '../styles/components/bottom-nav.css';

interface Props {
  currentPage?: string;
  variant?: 'main' | 'blog';
  lang?: 'en' | 'vi';
  slug?: string;
  langs?: ('en' | 'vi')[];
}

const {
  currentPage = '',
  variant = 'main',
  lang = 'en',
  slug = '',
  langs = ['en', 'vi']
} = Astro.props;

const navLinks = [
  { href: '/', label: 'home' },
  { href: '/projects', label: 'projects' },
  { href: '/blogs', label: 'blogs' },
];
---

<nav class="bottom-nav" aria-label="Navigation">
  <button
    id="bottom-back-to-top"
    class="bottom-nav__back-top"
    type="button"
    aria-label="Back to top"
  >↑</button>

  <div class="bottom-nav__z-group">
  <div class="bottom-nav__pill" id="nav-pill" aria-hidden="true">
    {variant === 'main' && navLinks.map(link => (
      <a
        class:list={['bottom-nav__link', { 'is-active': currentPage === link.label }]}
        href={link.href}
      >
        {link.label}
      </a>
    ))}

    {variant === 'blog' && (
      <>
        {lang === 'en' ? (
          langs.includes('vi') ? (
            <a href={`/blogs/vi/${slug}`} class="bottom-nav__link">vi</a>
          ) : (
            <span class:list={['bottom-nav__link', 'is-disabled']}>vi</span>
          )
        ) : (
          langs.includes('en') ? (
            <a href={`/blogs/en/${slug}`} class="bottom-nav__link">en</a>
          ) : (
            <span class:list={['bottom-nav__link', 'is-disabled']}>en</span>
          )
        )}
        <a href="/" class="bottom-nav__link">home</a>
        <a href="/blogs" class="bottom-nav__link">blogs</a>
      </>
    )}

    <span class="bottom-nav__row-break"></span>

    <a
      href="/contact"
      class:list={['bottom-nav__contact', { 'is-active': currentPage === 'contact' }]}
      aria-label="Contact"
    >ZSK</a>

    <span class="bottom-nav__divider"></span>

    <button
      id="terminal-trigger"
      class="bottom-nav__terminal"
      type="button"
      aria-label="Open terminal"
      aria-expanded="false"
      aria-controls="terminal-popup"
    >&gt;_</button>

    <span class="bottom-nav__divider"></span>

    <button
      id="bottom-theme-toggle"
      class="bottom-nav__theme"
      type="button"
      aria-label="Toggle theme"
    >
      <span class="bottom-nav__theme-icon">☀️</span>
    </button>
  </div>

  <button
    class="bottom-nav__toggle"
    id="nav-toggle"
    type="button"
    aria-label="Toggle navigation"
    aria-expanded="false"
    aria-controls="nav-pill"
  >Z</button>
  </div>
</nav>

<script>
  import { forceRepaint } from '../scripts/utils/dom';

  const bottomNav = document.querySelector('.bottom-nav') as HTMLElement;
  const navToggle = document.getElementById('nav-toggle') as HTMLButtonElement | null;
  const navPill = document.getElementById('nav-pill') as HTMLElement | null;

  function openNav(): void {
    bottomNav?.classList.add('is-open');
    navToggle?.setAttribute('aria-expanded', 'true');
    navPill?.setAttribute('aria-hidden', 'false');
  }

  function closeNav(): void {
    bottomNav?.classList.remove('is-open');
    navToggle?.setAttribute('aria-expanded', 'false');
    navPill?.setAttribute('aria-hidden', 'true');
  }

  function toggleNav(): void {
    bottomNav?.classList.contains('is-open') ? closeNav() : openNav();
  }

  navToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleNav();
  });

  document.addEventListener('click', (e) => {
    if (bottomNav && !bottomNav.contains(e.target as Node)) {
      closeNav();
    }
  });

  document.addEventListener('keydown', (e) => {
    const target = e.target as HTMLElement;
    if (target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement) return;
    if (target.isContentEditable) return;
    if (e.key === 'z' || e.key === 'Z') {
      e.preventDefault();
      toggleNav();
    }
  });

  // Close nav when terminal opens
  document.getElementById('terminal-trigger')?.addEventListener('click', closeNav);

  // Theme toggle
  const themeToggle = document.getElementById('bottom-theme-toggle');
  const themeIcon = themeToggle?.querySelector('.bottom-nav__theme-icon');

  function updateThemeIcon(): void {
    if (!themeIcon) return;
    const isDark = document.documentElement.dataset.theme === 'dark';
    themeIcon.textContent = isDark ? '🌙' : '☀️';
  }

  function toggleTheme(): void {
    const current = document.documentElement.dataset.theme;
    const next = current === 'dark' ? 'light' : 'dark';

    const style = document.createElement('style');
    style.textContent = '* { transition: none !important; }';
    document.head.appendChild(style);

    document.documentElement.dataset.theme = next;
    document.documentElement.style.colorScheme = next;
    localStorage.setItem('theme', next);

    updateThemeIcon();
    forceRepaint();

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        document.head.removeChild(style);
      });
    });

    window.dispatchEvent(new CustomEvent('themechange', { detail: { theme: next } }));
  }

  updateThemeIcon();

  const observer = new MutationObserver(updateThemeIcon);
  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme']
  });

  themeToggle?.addEventListener('click', toggleTheme);

  document.getElementById('bottom-back-to-top')?.addEventListener('click', (e) => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
    (e.currentTarget as HTMLButtonElement).blur();
  });

  // Footer collision detection
  const footer = document.querySelector('.footer') as HTMLElement;
  const spacing = 16;

  function isMobile(): boolean {
    return window.innerWidth <= 500;
  }

  function getDefaultBottom(): number {
    return isMobile() ? 16 : 24;
  }

  function updateNavPosition(): void {
    if (!bottomNav || !footer) return;

    const footerTop = footer.offsetTop;
    const navHeight = bottomNav.offsetHeight;
    const scrollY = window.scrollY;
    const windowHeight = window.innerHeight;
    const defaultBottom = getDefaultBottom();

    const navBottomWhenFixed = scrollY + windowHeight - defaultBottom;
    const collisionPoint = footerTop - spacing;

    if (navBottomWhenFixed > collisionPoint) {
      bottomNav.style.position = 'absolute';
      bottomNav.style.bottom = 'auto';
      bottomNav.style.top = `${footerTop - navHeight - spacing}px`;
    } else {
      bottomNav.style.position = '';
      bottomNav.style.bottom = '';
      bottomNav.style.top = '';
    }
  }

  let ticking = false;
  function onScroll(): void {
    if (!ticking) {
      requestAnimationFrame(() => {
        updateNavPosition();
        ticking = false;
      });
      ticking = true;
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', updateNavPosition);
  updateNavPosition();
</script>
