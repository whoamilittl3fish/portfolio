---
import "../styles/components/github-stats.css";
---

<div class="gh-activity" id="gh-activity" style="display: none;">
  <div class="gh-activity__container">
    <div class="gh-activity__label">
      <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none">
        <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
      </svg>
      <span>Latest Activity</span>
    </div>
    
    <div class="gh-activity__content" id="gh-activity-content">
      <a id="gh-repo-link" href="#" target="_blank" rel="noopener" class="gh-repo-name">...</a>
      <span class="gh-activity__divider">/</span>
      <span class="gh-commit-msg" id="gh-commit-msg">loading activity...</span>
      <span class="gh-activity__time" id="gh-commit-time"></span>
    </div>
  </div>
</div>

<script>
  async function fetchGitHubActivity() {
    const username = "whoamilittl3fish";
    const sectionEl = document.getElementById("github-activity-section");
    const containerEl = document.getElementById("gh-activity");
    const repoLinkEl = document.getElementById("gh-repo-link") as HTMLAnchorElement;
    const msgEl = document.getElementById("gh-commit-msg");
    const timeEl = document.getElementById("gh-commit-time");
    
    if (!sectionEl || !containerEl || !repoLinkEl || !msgEl || !timeEl) return;

    const CACHE_KEY = 'gh_activity_cache';
    const CACHE_EXPIRY = 10 * 60 * 1000; // 10 minutes
    
    try {
      const cachedStr = localStorage.getItem(CACHE_KEY);
      if (cachedStr) {
        const cached = JSON.parse(cachedStr);
        if (Date.now() - cached.timestamp < CACHE_EXPIRY) {
          renderActivity(cached.data);
          sectionEl.style.display = "block";
          containerEl.style.display = "block";
          return;
        }
      }

      const eventsRes = await fetch(`https://api.github.com/users/${username}/events/public?per_page=5`);
      if (!eventsRes.ok) throw new Error("Failed to fetch");
      
      const events = await eventsRes.json();
      const pushEvent = events.find((e: any) => e.type === "PushEvent" && e.payload.commits.length > 0);
      
      if (pushEvent) {
        const data = {
          repoName: pushEvent.repo.name.split('/')[1] || pushEvent.repo.name,
          repoUrl: `https://github.com/${pushEvent.repo.name}`,
          message: pushEvent.payload.commits[pushEvent.payload.commits.length - 1].message.split('\n')[0],
          time: pushEvent.created_at
        };

        localStorage.setItem(CACHE_KEY, JSON.stringify({
          timestamp: Date.now(),
          data: data
        }));

        renderActivity(data);
        sectionEl.style.display = "block";
        containerEl.style.display = "block";
      }
    } catch (error) {
      const cachedStr = localStorage.getItem(CACHE_KEY);
      if (cachedStr) {
        const cached = JSON.parse(cachedStr);
        renderActivity(cached.data);
        sectionEl.style.display = "block";
        containerEl.style.display = "block";
      }
    }
  }

  function renderActivity(data: any) {
    const repoLinkEl = document.getElementById("gh-repo-link") as HTMLAnchorElement;
    const msgEl = document.getElementById("gh-commit-msg");
    const timeEl = document.getElementById("gh-commit-time");

    if (repoLinkEl) {
      repoLinkEl.textContent = data.repoName;
      repoLinkEl.href = data.repoUrl;
    }
    if (msgEl) msgEl.textContent = data.message;
    if (timeEl) timeEl.textContent = timeAgo(new Date(data.time));
  }

  function timeAgo(date: Date) {
    const seconds = Math.floor((new Date().getTime() - date.getTime()) / 1000);
    if (seconds < 60) return "just now";
    const minutes = Math.floor(seconds / 60);
    if (minutes < 60) return minutes + "m ago";
    const hours = Math.floor(minutes / 60);
    if (hours < 24) return hours + "h ago";
    const days = Math.floor(hours / 24);
    return days + "d ago";
  }

  fetchGitHubActivity();
</script>
