---
import BaseLayout from '../components/BaseLayout.astro';
import '../styles/pages/contact.css';
---

<BaseLayout
  title="Contact | Khoa Ngo"
  description="Get in touch"
  currentPage="contact"
>
  <section class="contact-page">
    <div class="contact__container">

      <h1 class="contact__title">contact<span class="contact__title-dot">.</span></h1>

      <div class="contact__socials">
        <a
          href="https://github.com/whoamilittl3fish"
          target="_blank"
          rel="noopener"
          class="contact__social-link"
          aria-label="GitHub"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="40" height="40">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
        </a>
        <a
          href="mailto:khoa.ngovoviet@gmail.com"
          class="contact__social-link"
          aria-label="Email"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="40" height="40">
            <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
          </svg>
        </a>
        <a
          href="tel:+84966346694"
          class="contact__social-link"
          aria-label="Phone"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="40" height="40">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
        </a>
      </div>

      <div class="contact__form-section">
        <p class="contact__tagline">leave me a message<br>i'll remember you.</p>

        <form id="contact-form" class="contact__form">
          <div class="contact__field">
            <label class="contact__label" for="contact-name">name</label>
            <input
              id="contact-name"
              class="contact__input"
              type="text"
              name="name"
              required
              placeholder="your name"
              autocomplete="name"
            />
          </div>

          <div class="contact__field">
            <label class="contact__label" for="contact-email">email</label>
            <input
              id="contact-email"
              class="contact__input"
              type="email"
              name="email"
              required
              placeholder="your email"
              autocomplete="email"
            />
          </div>

          <div class="contact__field">
            <label class="contact__label" for="contact-message">message</label>
            <textarea
              id="contact-message"
              class="contact__textarea"
              name="message"
              required
              placeholder="your message"
              rows="5"
            ></textarea>
          </div>

          <div class="contact__field" style="display:none !important;">
            <label for="contact-website">website</label>
            <input id="contact-website" type="text" name="website" tabindex="-1" autocomplete="off" />
          </div>

          <div class="contact__actions">
            <button id="contact-submit" class="contact__submit" type="submit">send</button>
            <p id="contact-error" class="contact__error" aria-live="polite"></p>
          </div>
        </form>

        <div id="contact-success" class="contact__success" hidden>
          <p class="contact__success-msg">thank you, i'll get back to you.</p>
          <p class="contact__success-redirect">
            redirecting in <span id="contact-countdown">3</span>s…
          </p>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<script>
  const form      = document.getElementById('contact-form')     as HTMLFormElement | null;
  const submitBtn = document.getElementById('contact-submit')   as HTMLButtonElement | null;
  const errorEl   = document.getElementById('contact-error')    as HTMLElement | null;
  const successEl = document.getElementById('contact-success')  as HTMLElement | null;
  const countdown = document.getElementById('contact-countdown') as HTMLElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'sending…';
    if (errorEl) errorEl.textContent = '';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        body: new FormData(form!),
      });

      const data = await res.json().catch(() => ({}));

      if (res.ok) {
        window.location.href = '/thank-you';
      } else {
        const msg = (data as any)?.error ?? 'something went wrong, try again.';
        if (errorEl) errorEl.textContent = msg;
        submitBtn.disabled = false;
        submitBtn.textContent = 'send';
      }
    } catch {
      if (errorEl) errorEl.textContent = 'network error, try again.';
      submitBtn.disabled = false;
      submitBtn.textContent = 'send';
    }
  });
</script>
