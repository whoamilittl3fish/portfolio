---
import BaseLayout from "../components/BaseLayout.astro";
import { getEntry } from "astro:content";
import { marked } from "marked";
import GithubStats from "../components/GithubStats.astro";
import "../styles/pages/home.css";

const aboutEntry = await getEntry("home", "about");
const interestsEntry = await getEntry("home", "interests");

const timeline = aboutEntry?.data.timeline || [];
const { Content: InterestsContent } = interestsEntry
  ? await interestsEntry.render()
  : { Content: null };

function parseMarkdown(text: string): string {
  return marked.parseInline(text) as string;
}

const ASCII_ARTS = [
  {
    id: 'terminal',
    label: 'terminal',
    art: `  .---------.\n  | [] [] . |\n  | .  [] . |\n  | []  .   |\n  |_________|\n  |_________|\n   < code />`
  },
  {
    id: 'zsk',
    label: 'zsk',
    art: `    ______\n   /      \\\n  /  ZSK   \\\n /  z.s.k   \\\n(  zoskisk   )\n \\          /\n  \\________/`
  },
  {
    id: 'portfolio',
    label: 'portfolio',
    art: `  .---------.\n  | khoango |\n  |---------|\n  |projects |\n  | blogs   |\n  | contact |\n  '---------'`
  },
];
---

<BaseLayout
  title="Khoa Ngo | Web Developer Portfolio"
  description="Portfolio of Khoa Ngo (zoskisk) - Developer. I am very interesting in everything about programming, right now I learn how self-host all my thing from zoskisk.com with auth, vpn, ... If you found anything interesting, let's connect. Have a good day!"
  keywords="Khoa Ngo, Khoa, zsk, zosk ,zoskisk, web developer, portfolio, JavaScript, TypeScript, Node.js, Docker, C#, .NET, software engineer, Vietnam developer, self-host"
  currentPage="home"
>
  <section class="hero">
    <!-- Corner: left -->
    <div class="hero__corner hero__corner--left">
      <span>zoskisk.com</span>
      <span>/ home / VN</span>
      <span>remote @ PhuQuocDevs</span>
      <span>available for outsource</span>
    </div>

    <!-- Corner: right -->
    <div class="hero__corner hero__corner--right">
      <span>v1.0.0</span>
      <span>mood: caffeinated</span>
    </div>

    <div class="hero__container">
      <!-- Left: ASCII panel -->
      <div class="hero__ascii-panel">
        <div class="hero__ascii-stack">
          {ASCII_ARTS.map((item, i) => (
            <pre
              class:list={['hero__ascii-art', { 'is-active': i === 0 }]}
              data-index={i}
              set:text={item.art}
            ></pre>
          ))}
        </div>
        <div class="hero__ascii-dots">
          {ASCII_ARTS.map((item, i) => (
            <button
              class:list={['hero__ascii-dot', { 'is-active': i === 0 }]}
              data-index={i}
              type="button"
              aria-label={`Switch to ${item.label}`}
            ></button>
          ))}
        </div>
      </div>

      <!-- Right: content -->
      <div class="hero__content">
        <p class="hero__comment">// hello world</p>
        <h1 id="hero-title" class="is-typing"></h1>
        <p class="hero__tagline">Good things take time.</p>
        <p class="hero__terminal-hint">press <kbd>`</kbd> or <span>&gt;_</span> to explore · press <kbd>z</kbd> to open nav</p>
        <button id="scroll-to-about" class="btn"> ↓ my story </button>
      </div>
    </div>
  </section>

  <section id="about" class="section">
    <div class="section__container">
      <h2 class="section__title">about</h2>
      <ul class="timeline" aria-label="Timeline of my story">
        {
          timeline.map((item: { year: string; text: string }) => (
            <li class="timeline__item">
              <span class="timeline__year">{item.year}</span>
              <p class="timeline__text" set:html={parseMarkdown(item.text)} />
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="section__container">
      <h2 class="section__title">interests</h2>
      <div class="interests">
        {InterestsContent && <InterestsContent />}
      </div>
    </div>
  </section>

  <section id="github-activity-section" class="section" style="display: none;">
    <div class="section__container">
      <h2 class="section__title">github</h2>
      <GithubStats />
    </div>
  </section>

  <section id="contact" class="section">
    <div class="section__container">
      <p id="end-text" class="section__end text-muted"></p>
    </div>
  </section>
</BaseLayout>

<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify(
    {
      "@context": "https://schema.org",
      "@type": "Person",
      name: "Khoa Ngo",
      alternateName: "zoskisk",
      url: "https://zoskisk.vercel.app",
      image: "https://zoskisk.vercel.app/assets/icon/main.png",
      jobTitle: "Web Developer",
      description: "Web Developer specializing in JavaScript, TypeScript, Node.js, Docker, and C#/.NET",
      knowsAbout: ["Web Development","JavaScript","TypeScript","Node.js","Docker","C#",".NET","Git","Astro","Backend Development"],
      knowsLanguage: ["English", "Vietnamese"],
      sameAs: [
        "https://github.com/whoamilittl3fish",
        "https://www.codingame.com/profile/83603140793bc15d729e1516e11dda281538186",
      ],
    },
    null, 2,
  )}
/>

<script>
  // ── ASCII art switcher ─────────────────────────────────────────────────────
  const arts = document.querySelectorAll<HTMLElement>('.hero__ascii-art');
  const dots = document.querySelectorAll<HTMLButtonElement>('.hero__ascii-dot');
  const stack = document.querySelector<HTMLElement>('.hero__ascii-stack');

  function switchArt(next: number): void {
    arts.forEach(a => a.classList.remove('is-active'));
    dots.forEach(d => d.classList.remove('is-active'));
    arts[next]?.classList.add('is-active');
    dots[next]?.classList.add('is-active');
  }

  dots.forEach((dot, i) => dot.addEventListener('click', (e) => { e.stopPropagation(); switchArt(i); }));

  stack?.addEventListener('click', () => {
    const cur = [...arts].findIndex(a => a.classList.contains('is-active'));
    switchArt((cur + 1) % arts.length);
  });

  // ── Typewriter for hero title ──────────────────────────────────────────────
  const heroTitle = document.getElementById('hero-title') as HTMLElement | null;
  if (heroTitle) {
    const prefix = "Hi there,\nI'm ";
    const suffix = "Khoa.";
    heroTitle.textContent = prefix;
    let i = 0;
    function typeHero() {
      if (i <= suffix.length) {
        heroTitle!.textContent = prefix + suffix.slice(0, i);
        i++;
        setTimeout(typeHero, 70);
      } else {
        heroTitle!.classList.remove('is-typing');
      }
    }
    setTimeout(typeHero, 500);
  }

  // ── Scroll to about ────────────────────────────────────────────────────────
  const scrollButton = document.getElementById("scroll-to-about");
  const aboutSection = document.getElementById("about");
  if (scrollButton && aboutSection) {
    scrollButton.addEventListener("click", () => {
      const offset = aboutSection.getBoundingClientRect().top + window.pageYOffset - 60;
      window.scrollTo({ top: offset, behavior: "smooth" });
    });
  }

  // ── End text typing ────────────────────────────────────────────────────────
  const FULL_TEXT = "endl... that's all for now.";
  const endText = document.getElementById("end-text");
  let hasTyped = false;

  function typeEndText() {
    if (hasTyped || !endText) return;
    hasTyped = true;
    let index = 0;
    endText.textContent = "";
    endText.classList.add("typing");
    function type() {
      if (!endText) return;
      if (index < FULL_TEXT.length) {
        endText.textContent = FULL_TEXT.substring(0, index + 1);
        index++;
        setTimeout(type, 50);
      } else {
        endText.classList.remove("typing");
      }
    }
    type();
  }

  if (endText && "IntersectionObserver" in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !hasTyped) { typeEndText(); observer.disconnect(); }
        });
      },
      { rootMargin: "-100px 0px" },
    );
    observer.observe(endText);
  }
</script>

<style>
  #hero-title.is-typing::after {
    content: "|";
    animation: blink 0.75s step-end infinite;
    color: var(--accent);
    font-weight: 300;
  }

  #end-text.typing::after {
    content: "|";
    animation: blink 1s infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>
